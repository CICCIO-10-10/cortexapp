/**
 * modules/physicsMap.js — Phase 25
 *
 * MEGA FEATURE 3: Physics Mind Map — custom 60fps Force-Directed Graph Engine.
 * Estratto da main.js (MEGA FEATURE 3: PHYSICS MIND MAP block).
 *
 * Dipendenze iniettate via init():
 *   state             — app state (decks)
 *   toggleScrollLock  — abilita/disabilita scroll lock (opzionale)
 *
 * Import diretti:
 *   earnBadge         ← modules/gamification.js
 */
import { earnBadge } from './gamification.js';

// ── Dependency injection ──────────────────────────────────────────────────────

let _deps = {
    state:            { decks: [] },
    toggleScrollLock: null,
};

export function init(deps) { _deps = { ..._deps, ...deps }; }

// ── Stato modulo ──────────────────────────────────────────────────────────────

let physAnim       = null;
let physicsNodes   = [];
let physicsLinks   = [];
let mapDraggingNode = null;

// ── Helpers privati ───────────────────────────────────────────────────────────

function optimizeCanvas(canvas) {
    const dpr  = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width  = rect.width  * dpr;
    canvas.height = rect.height * dpr;
    const ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    return ctx;
}

// ── Public API ────────────────────────────────────────────────────────────────

export function openPhysicsMap(deckIdx) {
    const deck = _deps.state.decks[deckIdx];
    const text = deck ? (deck.text || deck.cards.map(p => p.q + ' ' + p.a).join(' ')) : '';
    document.getElementById('mindmap-overlay').style.display = 'flex';
    buildPhysicsGraph(text, deck ? deck.name : 'Mind Map');
}

export function closePhysicsGraph() {
    if (physAnim) {
        cancelAnimationFrame(physAnim);
        physAnim = null;
    }
    const overlay = document.getElementById('mindmap-overlay');
    if (overlay) overlay.style.display = 'none';
    if (typeof _deps.toggleScrollLock === 'function') _deps.toggleScrollLock(false);
}

export function buildPhysicsGraph(text, title) {
    if (physAnim) cancelAnimationFrame(physAnim);
    const canvas = document.getElementById('physics-canvas');
    if (!canvas) return;

    // Ottimizzazione Canvas DPR
    optimizeCanvas(canvas);
    const rect = canvas.getBoundingClientRect();
    const W = rect.width;
    const H = rect.height;

    // Extract top concepts
    const stopwords = new Set(['il', 'la', 'le', 'i', 'gli', 'un', 'una', 'uno', 'di', 'da', 'in', 'con', 'su', 'per', 'tra', 'fra', 'che', 'è', 'e', 'a', 'o', 'ma', 'non', 'si', 'lo', 'ne', 'se', 'al', 'del', 'dei', 'delle', 'dalla', 'dallo', 'agli', 'dai', 'nelle', 'nella', 'nel', 'dei', 'nei', 'come', 'cosa', 'questo', 'questa', 'questi', 'queste', 'anche', 'più', 'tutto', 'tutti', 'però', 'dopo', 'prima', 'quando', 'dove', 'perché', 'poi', 'già', 'ancora', 'sempre', 'mai', 'ogni', 'molto', 'poco', 'troppo', 'bene', 'male', 'fare', 'avere', 'essere', 'stai', 'sono', 'sei', 'siamo', 'hanno', 'ha', 'hai', 'aveva', 'era', 'nel', 'negli', 'suo', 'sua', 'suoi', 'sue', 'mio', 'mia', 'tuoi', 'noi', 'voi', 'loro', 'lui', 'lei', 'quale', 'quella', 'quello']);
    const words = text.toLowerCase().match(/\b[a-zA-ZàèéìíîòóùúÀÈÉÌÍÎÒÓÙÚ]{4,}\b/g) || [];
    const freq  = {};
    words.forEach(w => { if (!stopwords.has(w)) freq[w] = (freq[w] || 0) + 1; });
    const top = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 10).map(e => e[0]);

    physicsNodes = [{ id: 'center', lbl: title.slice(0, 20), x: W / 2, y: H / 2, vx: 0, vy: 0, r: 40, col: '#7c6af7', mass: 5 }];
    physicsLinks = [];
    const colors = ['#10b981', '#f59e0b', '#ec4899', '#06b6d4', '#ef4444', '#8b5cf6', '#f97316'];

    top.forEach((word, i) => {
        const angle = (i / top.length) * 2 * Math.PI;
        const rInit = 80;
        const node  = {
            id: 'n' + i, lbl: word,
            x: W / 2 + rInit * Math.cos(angle),
            y: H / 2 + rInit * Math.sin(angle),
            vx: 0, vy: 0, r: 35, col: colors[i % colors.length], mass: 1
        };
        physicsNodes.push(node);
        physicsLinks.push({ s: physicsNodes[0], t: node });
    });

    // Interactions
    let isDragging = false;
    canvas.onmousedown = (e) => {
        const rect = canvas.getBoundingClientRect();
        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
        for (let n of physicsNodes) {
            const dx = mx - n.x, dy = my - n.y;
            if (dx * dx + dy * dy <= n.r * n.r) { isDragging = true; mapDraggingNode = n; break; }
        }
    };
    canvas.onmousemove = (e) => {
        if (!isDragging || !mapDraggingNode) return;
        const rect = canvas.getBoundingClientRect();
        mapDraggingNode.x  = e.clientX - rect.left;
        mapDraggingNode.y  = e.clientY - rect.top;
        mapDraggingNode.vx = 0; mapDraggingNode.vy = 0;
    };
    canvas.onmouseup    = () => { isDragging = false; mapDraggingNode = null; };
    canvas.onmouseleave = () => { isDragging = false; mapDraggingNode = null; };

    const ctx = canvas.getContext('2d');
    function step() {
        // Physics Euler Integration
        const kSpring = 0.05, linkDist = 180, repulse = 5000, damp = 0.85;

        // Repulsion
        for (let i = 0; i < physicsNodes.length; i++) {
            for (let j = i + 1; j < physicsNodes.length; j++) {
                const a = physicsNodes[i], b = physicsNodes[j];
                let dx = a.x - b.x, dy = a.y - b.y;
                let dSq = dx * dx + dy * dy;
                if (dSq < 1) dSq = 1;
                const dist = Math.sqrt(dSq);
                const f  = repulse / dSq;
                const fx = (dx / dist) * f, fy = (dy / dist) * f;
                a.vx += fx / a.mass; a.vy += fy / a.mass;
                b.vx -= fx / b.mass; b.vy -= fy / b.mass;
            }
        }
        // Springs
        for (let l of physicsLinks) {
            const dx   = l.t.x - l.s.x, dy = l.t.y - l.s.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const diff = dist - linkDist;
            const f    = diff * kSpring;
            const fx   = (dx / dist) * f, fy = (dy / dist) * f;
            l.s.vx += fx / l.s.mass; l.s.vy += fy / l.s.mass;
            l.t.vx -= fx / l.t.mass; l.t.vy -= fy / l.t.mass;
        }
        // Update & Render
        ctx.clearRect(0, 0, W, H);

        // Draw Links
        ctx.lineWidth = 2;
        for (let l of physicsLinks) {
            ctx.strokeStyle = l.t.col; ctx.globalAlpha = 0.5;
            ctx.beginPath(); ctx.moveTo(l.s.x, l.s.y); ctx.lineTo(l.t.x, l.t.y); ctx.stroke();
        }
        ctx.globalAlpha = 1.0;

        // Move & Draw Nodes
        ctx.font = '700 13px Inter'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        for (let n of physicsNodes) {
            if (n !== mapDraggingNode && n.id !== 'center') {
                n.vx *= damp; n.vy *= damp;
                n.x  += n.vx; n.y += n.vy;
                // Borders
                if (n.x < n.r) n.x = n.r; if (n.x > W - n.r) n.x = W - n.r;
                if (n.y < n.r) n.y = n.r; if (n.y > H - n.r) n.y = H - n.r;
            } else if (n.id === 'center' && n !== mapDraggingNode) {
                // center gravity
                n.x += (W / 2 - n.x) * 0.1; n.y += (H / 2 - n.y) * 0.1;
            }

            ctx.fillStyle = n.col;
            ctx.beginPath();
            if (n.id === 'center') { ctx.roundRect(n.x - n.lbl.length * 4 - 20, n.y - 20, n.lbl.length * 8 + 40, 40, 20); ctx.fill(); }
            else { ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2); ctx.fill(); }

            ctx.fillStyle = '#fff';
            ctx.fillText(n.lbl, n.x, n.y);
        }
        physAnim = requestAnimationFrame(step);
    }
    step();
    earnBadge('grafo_master');
}
